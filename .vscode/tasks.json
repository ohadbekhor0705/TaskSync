{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Blazor Watch",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}\\Frontend"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "new"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}