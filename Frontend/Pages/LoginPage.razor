@page "/login"
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.ComponentModel.DataAnnotations
@using UserModels
@using System.Net.Http.Json
@using System.Text.Json.Nodes;

@inject IJSRuntime JS

<div class="login-page">
    <div class="login-background shape-one"></div>
    <div class="login-background shape-two"></div>

    <div class="login-layout">
        <div class="login-info">
            <h1>Welcome back to <span>TaskSync</span></h1>

            <p>
                Sign in to pick up where you left off and keep your
                workspace moving.
            </p>

            <div class="info-item">
                <strong>✓ Simple workflow</strong>
                <span>Create and manage tasks easily</span>
            </div>

            <div class="info-item">
                <strong>✓ Stay organized</strong>
                <span>Track your progress every day</span>
            </div>

            <div class="info-item">
                <strong>✓ Secure account</strong>
                <span>Your data stays private</span>
            </div>
        </div>

        <div class="login-card shadow-lg">
            <div class="text-center mb-4">
                <h2 class="fw-bold">Login</h2>
                <p class="text-muted">Sign in to your TaskSync account</p>
            </div>

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Username</label>

                    <InputText class="form-control custom-input"
                               @bind-Value="loginModel.Username"
                               placeholder="Username" />

                    <ValidationMessage For="@(() => loginModel.Username)"
                                       class="validation-text" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>

                    <InputText type="password"
                               class="form-control custom-input"
                               @bind-Value="loginModel.Password"
                               placeholder="Password" />

                    <ValidationMessage For="@(() => loginModel.Password)"
                                       class="validation-text" />
                </div>

                @if (success == false){
                
                    <div class="alert-error mb-3">@responseMessage</div>
                }

                <button disabled="@isSubmitting" class="login-btn">@(isSubmitting? "Logging in...." : "Login")</button>

                <div class="text-center mt-4">
                    <small class="text-muted">
                        Don't have an account?
                        <a href="/register">Create one</a>
                    </small>
                </div>
            </EditForm>
        </div>
    </div>
</div>


<style>
    .login-page {

    min-height:100vh;

    background:#f5f5f5;

    display:flex;

    justify-content:center;

    align-items:center;

    overflow:hidden;

    position:relative;

    padding:40px;

}


.login-layout {

    width:100%;

    max-width:1100px;

    display:flex;

    align-items:center;

    gap:80px;

    position:relative;

    z-index:2;

}


.login-info {

    flex:1;

}


.login-info h1 {

    font-size:60px;

    font-weight:800;

    color:#111;

}


.login-info h1 span {

    color:#555;

}


.login-info p {

    color:#666;

    font-size:18px;

    max-width:400px;

}


.info-item {

    margin-top:30px;

    display:flex;

    flex-direction:column;

}


.info-item strong {

    font-size:18px;

}


.info-item span {

    color:#777;

}



.login-card {

    background:white;

    width:430px;

    padding:40px;

    border-radius:25px;

}


.custom-input {

    height:48px;

    border-radius:12px;

    border:1px solid #ddd;

}


.custom-input:focus {

    border-color:#111;

    box-shadow:0 0 0 4px rgba(0,0,0,.08);

}



.login-btn {

    width:100%;

    height:50px;

    border:none;

    border-radius:12px;

    background:#111;

    color:white;

    font-weight:700;

}


.login-btn:hover {

    background:#000;

}


.alert-error {

    background:#fdeaea;

    color:#a10000;

    border:1px solid #f3c2c2;

    border-radius:10px;

    padding:10px 14px;

    font-size:14px;

    text-align:center;

}



.login-background {

    position:absolute;

    border-radius:50%;

    background:#111;

    opacity:.04;

}


.shape-one {

    width:500px;

    height:500px;

    top:-200px;

    right:-200px;

}


.shape-two {

    width:350px;

    height:350px;

    bottom:-150px;

    left:-150px;

}



@@media(max-width:900px){

    .login-layout {

        flex-direction:column;

        gap:40px;

    }


    .login-info {

        text-align:center;

    }


    .login-card {

        width:100%;

        max-width:430px;

    }

}

</style>

@code {
    private string? savedToken = null;
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (!firstRender)
            return;
        savedToken = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (!string.IsNullOrEmpty(savedToken)) {
            Navigation.NavigateTo("/dashboard");
            return;
        }
    }
    private bool isSubmitting = false;
    private UserLogin loginModel = new UserLogin();
    private bool? success = null;
    private string responseMessage = string.Empty;
    private LoginResponse? loginResponse = null;

    public class UserLogin {
    
        [Required(ErrorMessage = "Username is required.")]
        [StringLength(20, MinimumLength = 3, ErrorMessage = "Username must be between 3 and 20 characters.")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters long.")]
        public string Password { get; set; } = "";
    }

    private async Task HandleLogin() {
  
        try {
            isSubmitting = true;
            HttpResponseMessage? response = await Http.PostAsJsonAsync("http://127.0.0.1:8000/users/login", loginModel);
            if (response != null && response.IsSuccessStatusCode) {
                loginResponse = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (loginResponse != null && !string.IsNullOrEmpty(loginResponse.AccessToken))
                    await JS.InvokeVoidAsync("localStorage.setItem", "authToken", loginResponse.AccessToken);
                    responseMessage = loginResponse.message;
                success = true;
                await Task.Delay(3000);
                Navigation.NavigateTo("/dashboard");
            }
            else {
                success = false;
                JsonNode root = await response.Content.ReadFromJsonAsync<JsonNode>();
                responseMessage = root["detail"]?.ToString();
            }
                
                
                
        }
        catch {
            success = false;
            responseMessage = "Internal Server Error";
        }
        finally {
            isSubmitting = false;
            StateHasChanged();
        }
            
    }
}