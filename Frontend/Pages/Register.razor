@page "/register"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
<!--!?
    This is the Register page for the TaskSync application.
    It allows users to create a new account by providing a username, email, and password.
    The form data is sent to the backend API for user registration.
    The page includes validation for the input fields and displays error messages if the registration fails.
!-->

<div class="register-page">

    <div class="register-background shape-one"></div>
    <div class="register-background shape-two"></div>


    <div class="register-layout">


        <!-- Left Content -->

        <div class="register-info">

            <h1>
                Join
                <span>TaskSync</span>
            </h1>

            <p>
                Start organizing your tasks and improve your productivity
                with a simple and powerful workspace.
            </p>


            <div class="info-item">
                <strong>✓ Simple workflow</strong>
                <span>Create and manage tasks easily</span>
            </div>


            <div class="info-item">
                <strong>✓ Stay organized</strong>
                <span>Track your progress every day</span>
            </div>


            <div class="info-item">
                <strong>✓ Secure account</strong>
                <span>Your data stays private</span>
            </div>


        </div>



        <!-- Register Card -->

        <div class="register-card shadow-lg">


            <div class="text-center mb-4">

                <h2 class="fw-bold">
                    Create Account
                </h2>

                <p class="text-muted">
                    Start your TaskSync journey
                </p>

            </div>


            <EditForm Model="@userModel" OnValidSubmit="HandleRegister">

                <DataAnnotationsValidator />

                @if (responseMessage != string.Empty) {
                    <div class="alert @(isSuccessful? "alert-success": "alert-danger")" role="alert">@responseMessage</div>
                }
                <div class="mb-3">

                    <label class="form-label">
                        Username
                    </label>

                    <InputText class="form-control custom-input"
                               @bind-Value="userModel.Username"
                               placeholder="Username" />

                    <ValidationMessage For="@(() => userModel.Username)"
                                       class="validation-text" />

                </div>
                <div class="mb-3">

                    <label class="form-label">
                        Email
                    </label>

                    <InputText type="email"
                               class="form-control custom-input"
                               @bind-Value="userModel.Email"
                               placeholder="Email address" />

                    <ValidationMessage For="@(() => userModel.Email)"
                                       class="validation-text" />

                </div>
                <div class="mb-4">

                    <label class="form-label">
                        Password
                    </label>

                    <InputText type="password"
                               class="form-control custom-input"
                               @bind-Value="userModel.Password"
                               placeholder="Password" />

                    <ValidationMessage For="@(() => userModel.Password)"
                                       class="validation-text" />

                </div>


                <button class="register-btn" disabled="@isSubmitting">
                    @( isSubmitting ? "Creating Account..." : " Create Account")
                </button>


                <div class="text-center mt-4">

                    <small class="text-muted">

                        Already registered?

                        <a href="/login">
                            Login
                        </a>

                    </small>

                </div>


            </EditForm>
        </div>

    </div>
</div>
<style>
.register-page {

    min-height:100vh;

    background:#f5f5f5;

    display:flex;

    justify-content:center;

    align-items:center;

    overflow:hidden;

    position:relative;

    padding:40px;

}


.register-layout {

    width:100%;

    max-width:1100px;

    display:flex;

    align-items:center;

    gap:80px;

    position:relative;

    z-index:2;

}


.register-info {

    flex:1;

}


.register-info h1 {

    font-size:60px;

    font-weight:800;

    color:#111;

}


.register-info h1 span {

    color:#555;

}


.register-info p {

    color:#666;

    font-size:18px;

    max-width:400px;

}


.info-item {

    margin-top:30px;

    display:flex;

    flex-direction:column;

}


.info-item strong {

    font-size:18px;

}


.info-item span {

    color:#777;

}



.register-card {

    background:white;

    width:430px;

    padding:40px;

    border-radius:25px;

}


.custom-input {

    height:48px;

    border-radius:12px;

    border:1px solid #ddd;

}


.custom-input:focus {

    border-color:#111;

    box-shadow:0 0 0 4px rgba(0,0,0,.08);

}



.register-btn {

    width:100%;

    height:50px;

    border:none;

    border-radius:12px;

    background:#111;

    color:white;

    font-weight:700;

}


.register-btn:hover {

    background:#000;

}



.register-background {

    position:absolute;

    border-radius:50%;

    background:#111;

    opacity:.04;

}


.shape-one {

    width:500px;

    height:500px;

    top:-200px;

    right:-200px;

}


.shape-two {

    width:350px;

    height:350px;

    bottom:-150px;

    left:-150px;

}



@@media(max-width:900px){

    .register-layout {

        flex-direction:column;

        gap:40px;

    }


    .register-info {

        text-align:center;

    }


    .register-card {

        width:100%;

        max-width:430px;

    }

}
</style>

@code {
    private UserRegister userModel = new UserRegister();
    private bool isSubmitting = false;
    private bool isSuccessful = false;
    private string responseMessage {get; set; } = string.Empty;


    public class UserRegister 
    {
        [Required(ErrorMessage = "Username is required.")]
        [StringLength(20, MinimumLength = 3, ErrorMessage = "Username must be between 3 and 20 characters.")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email address format.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters long.")]
        public string Password { get; set; } = "";
    }

    private async Task HandleRegister() { 
        try {
            isSubmitting = true;
            // sending post request:
            var response = await Http.PostAsJsonAsync("http://127.0.0.1:8000/users/register", userModel);
            
            if (response.IsSuccessStatusCode) {
                isSuccessful = true;
                await Task.Delay(2000);
                Navigation.NavigateTo("/login");
                return;
            }
            else {
                isSuccessful = false;
            }
        }
        catch (Exception) {
            responseMessage = "Something went wrong with the server!";
        }
        finally {
            isSubmitting = false;
            StateHasChanged();
        }
    }
    private string? savedToken = null;
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (!firstRender)
            return;
        savedToken = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        StateHasChanged();
        if (!string.IsNullOrEmpty(savedToken)) {
            Navigation.NavigateTo("/dashboard");
            return;
        }
    }
    private async Task<string> getMessage(HttpResponseMessage response) {
        var detail = await response.Content.ReadFromJsonAsync<Dictionary<string, object>>();
        if (detail != null && detail.ContainsKey("detail")) {
            return detail["detail"]?.ToString();
        }
        return "";
    }
}