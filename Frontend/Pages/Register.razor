@page "/register"
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
<!--!?
    This is the Register page for the TaskSync application.
    It allows users to create a new account by providing a username, email, and password.
    The form data is sent to the backend API for user registration.
    The page includes validation for the input fields and displays error messages if the registration fails.
!-->


<h3>Login to TaskSync</h3>

<div class="register-container">

    <div class="register-card shadow-lg">

        @if (success != null){
            if (!(bool)success) {
                <div class="alert alert-danger mt-3 mx-auto" style="max-width: 450px;">@responseMessage</div>
            }
            else{
                <div class="alert alert-success mt-3 mx-auto" style="max-width: 450px;">@responseMessage</div>
            }
            
        }
        <div class="text-center mb-4">
            <h2 class="fw-bold">Create Account</h2>
            <p class="text-muted">Join us today and get started</p>
        </div>

        <EditForm Model="@userModel" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Username</label>
                <InputText class="form-control custom-input"
                           @bind-Value="userModel.Username"
                           placeholder="Choose a username" />

                <ValidationMessage For="@(() => userModel.Username)"
                                   class="validation-text" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <InputText type="email"
                           class="form-control custom-input"
                           @bind-Value="userModel.Email"
                           placeholder="you@example.com" />

                <ValidationMessage For="@(() => userModel.Email)"
                                   class="validation-text" />
            </div>

            <div class="mb-4">
                <label class="form-label">Password</label>
                <InputText type="password"
                           class="form-control custom-input"
                           @bind-Value="userModel.Password"
                           placeholder="Create a strong password" />

                <ValidationMessage For="@(() => userModel.Password)"
                                   class="validation-text" />
            </div>

            <button type="submit" class="register-btn">
                Create Account
            </button>

            <div class="text-center mt-4">
                <small class="text-muted">
                    Already have an account?
                    <a href="/login" class="login-link">Login</a>
                </small>
            </div>

        </EditForm>

    </div>

</div>


<style>
    .register-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        padding: 20px;
    }

    .register-card {
        background: white;
        width: 100%;
        max-width: 430px;
        padding: 40px;
        border-radius: 20px;
        animation: fadeIn 0.4s ease;
    }

    .register-card h2 {
        color: #333;
    }

    .form-label {
        font-weight: 600;
        color: #444;
    }

    .custom-input {
        height: 48px;
        border-radius: 12px;
        border: 1px solid #ddd;
        padding: 0 15px;
        transition: .2s;
    }

    .custom-input:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102,126,234,.15);
    }

    .register-btn {
        width: 100%;
        height: 50px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg,#667eea,#764ba2);
        color: white;
        font-weight: 700;
        font-size: 16px;
        transition: .2s;
    }

    .register-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102,126,234,.35);
    }

    .validation-text {
        color: #dc3545;
        font-size: 13px;
    }

    .login-link {
        color: #667eea;
        font-weight: 600;
        text-decoration: none;
    }

    .login-link:hover {
        text-decoration: underline;
    }

   
</style>

@code {
    private UserRegister userModel = new UserRegister();
    private bool? success = null;
    private string responseMessage {get; set; } = string.Empty;


    public class UserRegister 
    {
        [Required(ErrorMessage = "Username is required.")]
        [StringLength(20, MinimumLength = 3, ErrorMessage = "Username must be between 3 and 20 characters.")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email address format.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters long.")]
        public string Password { get; set; } = "";
    }

    private async Task HandleRegister() {
        try {
            // sending post request:
            var response = await Http.PostAsJsonAsync("http://127.0.0.1:8000/users/register", userModel);
            responseMessage = await getMessage(response);
            if (response.IsSuccessStatusCode) {
                success = true;
                StateHasChanged();
                await Task.Delay(2000);
                Navigation.NavigateTo("/login");
            }
            else {
                success = false;
            }
        }
        catch (Exception) {
            success = false;
            responseMessage = "Something went wrong with the server!";
        }
    }
    private async Task<string> getMessage(HttpResponseMessage response) {
        var detail = await response.Content.ReadFromJsonAsync<Dictionary<string, object>>();
        if (detail != null && detail.ContainsKey("message")) {
            return detail["message"]?.ToString();
        }
        return "";
    }
}