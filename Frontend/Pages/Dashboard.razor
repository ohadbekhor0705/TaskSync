@page "/dashboard"
@inject IJSRuntime JS
@inject NavigationManager Navigation
@using TodoModels
@using System.Net.Http.Headers
@using System.Net.Http.Json
@inject HttpClient Http
@if (todoModels == null) {
    <div class="loader">

        <div class="todo-list">

            <div class="todo">
                <div class="checkbox">
                    <div class="checkmark"></div>
                </div>
                <div class="task"></div>
            </div>

            <div class="todo">
                <div class="checkbox">
                    <div class="checkmark"></div>
                </div>
                <div class="task"></div>
            </div>

            <div class="todo">
                <div class="checkbox">
                    <div class="checkmark"></div>
                </div>
                <div class="task"></div>
            </div>

            <div class="todo">
                <div class="checkbox">
                    <div class="checkmark"></div>
                </div>
                <div class="task"></div>
            </div>

        </div>

        <div class="loading-text">
            Loading your tasks<span class="dots"></span>
        </div>

    </div>
}
else {

<div class="container py-5">

  <div class="todo-header mb-4">
    <h1 class="h3 mb-1">Todo Board</h1>
    @* <p class="text-secondary mb-0">Bootstrap grid/flexbox template.</p> *@
  </div>
  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
    @foreach (TodoModel todo in todoModels) {
        <TodoItemComponent Todo="todo" authToken="@savedToken"/>
    }
  </div>
</div>
}

<style>
  body {
    background-color: #f4f4f6;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    color: #1a1a1a;
  }
  .todo-header h1 {
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #111;
  }
  .todo-card {
    background-color: #ffffff;
    border: 1px solid #e5e5e8;
    border-radius: .75rem;
    box-shadow: 0 1px 2px rgba(0,0,0,.04);
    transition: transform .15s ease, box-shadow .15s ease;
  }
  .todo-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0,0,0,.08);
  }
  .todo-title {
    font-weight: 600;
    color: #111;
    word-break: break-word;
  }
  .todo-card.is-completed .todo-title {
    text-decoration: line-through;
    color: #9a9a9e;
  }
  .status-badge {
    font-weight: 500;
    font-size: .75rem;
    letter-spacing: .02em;
    padding: .4em .75em;
    border-radius: 999px;
    white-space: nowrap;
  }
  .status-pending     { background-color: #fff4d6; color: #8a6100; }
  .status-in_progress { background-color: #e7e2ff; color: #4b32c3; }
  .status-completed   { background-color: #dcf6e9; color: #0f7a45; }
  .btn-black {
    background-color: #111;
    color: #fff;
    border: 1px solid #111;
  }
  .btn-black:hover { background-color: #000; color: #fff; }
  .btn-black-outline {
    background-color: #fff;
    color: #111;
    border: 1px solid #111;
  }
  .btn-black-outline:hover { background-color: #111; color: #fff; }


* {
            box-sizing: border-box;
        }



        .loader {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 18px;
            margin: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f5f7fb;
            font-family: Arial, sans-serif;
        }

        .todo-list {
            width: 260px;
            padding: 20px;
            background: white;
            border-radius: 14px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .todo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 14px;
        }

        .todo:last-child {
            margin-bottom: 0;
        }

        .checkbox {
            position: relative;
            width: 20px;
            height: 20px;
            border: 2px solid #6366f1;
            border-radius: 5px;
            flex-shrink: 0;
        }

        .checkmark {
            position: absolute;
            left: 4px;
            top: 1px;
            width: 8px;
            height: 13px;
            border-right: 2px solid white;
            border-bottom: 2px solid white;
            transform: rotate(45deg) scale(0);
            animation: check 2.4s infinite;
        }

        .todo:nth-child(1) .checkmark {
            animation-delay: 0s;
        }

        .todo:nth-child(2) .checkmark {
            animation-delay: 0.5s;
        }

        .todo:nth-child(3) .checkmark {
            animation-delay: 1s;
        }

        .todo:nth-child(4) .checkmark {
            animation-delay: 1.5s;
        }

        .todo:nth-child(1) .checkbox {
            animation-delay: 0s;
        }

        .todo:nth-child(2) .checkbox {
            animation-delay: 0.5s;
        }

        .todo:nth-child(3) .checkbox {
            animation-delay: 1s;
        }

        .todo:nth-child(4) .checkbox {
            animation-delay: 1.5s;
        }

        .task {
            height: 8px;
            border-radius: 10px;
            background: #e5e7eb;
            width: 150px;
            position: relative;
            overflow: hidden;
        }

        .task::after {
            content: "";
            position: absolute;
            inset: 0;
            background: #6366f1;
            transform: translateX(-100%);
            animation: taskComplete 2.4s infinite;
        }

        .todo:nth-child(1) .task::after {
            animation-delay: 0s;
        }

        .todo:nth-child(2) .task::after {
            animation-delay: 0.5s;
        }

        .todo:nth-child(3) .task::after {
            animation-delay: 1s;
        }

        .todo:nth-child(4) .task::after {
            animation-delay: 1.5s;
        }

        .loading-text {
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
        }

        .dots::after {
            content: "";
            animation: dots 1.5s infinite;
        }

        @@keyframes check {
            0%, 20% {
                transform: rotate(45deg) scale(0);
            }

            30%, 70% {
                transform: rotate(45deg) scale(1);
            }

            80%, 100% {
                transform: rotate(45deg) scale(0);
            }
        }

        @@keyframes taskComplete {
            0%, 20% {
                transform: translateX(-100%);
            }

            40%, 70% {
                transform: translateX(0);
            }

            90%, 100% {
                transform: translateX(100%);
            }
        }

        @@keyframes dots {
            0% {
                content: "";
            }

            33% {
                content: ".";
            }

            66% {
                content: "..";
            }

            100% {
                content: "...";
            }
        }
</style>
@code {
    private string? savedToken = null;
    TodoModel[]? todoModels = null;
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (!firstRender)
            return;
        savedToken = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (string.IsNullOrEmpty(savedToken)) {
            Navigation.NavigateTo("/");
            return;
        }
        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", savedToken);
        await Task.Delay(2000);
        todoModels = await Http.GetFromJsonAsync<TodoModel[]>("http://127.0.0.1:8000/todos/");
        StateHasChanged();
    }
    @* protected override async Task OnInitializedAsync() {
        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", savedToken);
        todoModels = await Http.GetFromJsonAsync<TodoModel[]>("http://127.0.0.1:8000/todos/");
    } *@


    
}